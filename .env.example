NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/sos
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Secretos: generar valores aleatorios distintos, nunca reutilizar los de demo.
SOS_SESSION_SECRET=replace-with-at-least-48-random-bytes
VSTI_TOKEN=replace-with-device-integration-token
ADMIN_TOKEN=replace-with-break-glass-admin-token
OTP_HASH_SECRET=replace-with-independent-otp-hash-secret

# Dominio público canónico de la API QUELTU.
SOS_PUBLIC_BASE_URL=https://api.queltu.com

# Opcional: solo permite sobrescribir el destino de los QR sin cambiar código.
# SOS_PWA_BASE_URL=https://app.queltu.com

# Orígenes exactos separados por coma. Mantener temporalmente los hosts heredados activos.
CORS_ALLOWED_ORIGINS=https://app.queltu.com,https://response.queltu.com,https://control.queltu.com,https://dashboard.queltu.com,https://admin.queltu.com,https://superadmin.queltu.com,https://sos-admin-ipp7.onrender.com,https://sos-dashboard-3695.onrender.com,https://mapa.sos.vsti.cl,https://sos-map.onrender.com,https://sos-pwa.onrender.com,https://sos-resolver-pwa.onrender.com,https://sos-superadmin.onrender.com,capacitor://localhost,ionic://localhost,https://localhost,http://localhost

# Twilio Verify (producción)
OTP_PROVIDER=twilio_verify
OTP_DEFAULT_CHANNEL=sms
OTP_REQUIRE_DELIVERY=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Demo controlada: habilitar solo en un entorno demo aislado.
OTP_DEMO_MODE=false
OTP_EXPOSE_DEMO_CODE=false
PHONE_LOCATION_REQUEST_TTL_MINUTES=20
PHONE_LOCATION_MAX_ACCURACY_METERS=200
PHONE_LOCATION_ABSOLUTE_MAX_ACCURACY_METERS=5000
LOCATION_REQUEST_RATE_LIMIT_MAX=20
OTP_LOG_CODES=false
SOS_SECURITY_DEMO_MODE=false

# Debug cerrado por defecto. Si se habilita, igualmente exige ADMIN_TOKEN.
SOS_DEBUG_ENDPOINTS_ENABLED=false
AUTH_DEMO_LOGIN_ENABLED=false
AUTH_RATE_LIMIT_MAX=20
PANEL_SESSION_TTL_HOURS=12
